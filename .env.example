APP_NAME=GuitarOnline
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
LOG_LEVEL=INFO

SECRET_KEY=change-me-in-production
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
FRONTEND_ADMIN_ORIGIN=http://localhost:5173
KPI_EXCLUDED_EMAIL_PREFIXES=synthetic-ops-
AUTH_RATE_LIMIT_BACKEND=memory
AUTH_RATE_LIMIT_REDIS_NAMESPACE=auth_rate_limit
AUTH_SELF_REGISTRATION_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REGISTER_REQUESTS=5
AUTH_RATE_LIMIT_LOGIN_REQUESTS=10
AUTH_RATE_LIMIT_REFRESH_REQUESTS=20
AUTH_REFRESH_COOKIE_NAME=go_refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/api/v1/identity/auth
AUTH_RATE_LIMIT_TRUSTED_PROXY_IPS=127.0.0.1,::1
AUTH_RATE_LIMIT_ALLOW_IN_MEMORY_IN_PRODUCTION=false

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=guitaronline
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/guitaronline

BOOKING_HOLD_MINUTES=10
BOOKING_REFUND_WINDOW_HOURS=24
SYNTHETIC_RETENTION_DAYS=14
SYNTHETIC_RETENTION_EMAIL_PREFIXES=synthetic-ops-
SYNTHETIC_RETENTION_DRY_RUN=false
BOOKING_HOLDS_EXPIRER_MODE=once
BOOKING_HOLDS_EXPIRER_POLL_SECONDS=30
BOOKING_HOLDS_EXPIRER_LOG_LEVEL=INFO
PACKAGES_EXPIRER_MODE=once
PACKAGES_EXPIRER_POLL_SECONDS=3600
PACKAGES_EXPIRER_LOG_LEVEL=INFO
LESSON_MEETING_URL_TEMPLATE=
ADMIN_UI_API_BASE_URL=/api/v1
ADMIN_UI_BASE_PATH=/admin/
DEPLOY_SMOKE_ADMIN_EMAIL=
DEPLOY_SMOKE_ADMIN_PASSWORD=

REDIS_URL=redis://redis:6379/0
GRAFANA_ADMIN_USER=grafana_admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin-password
ALERTMANAGER_SLACK_WEBHOOK_URL=
ALERTMANAGER_SLACK_CHANNEL=#ops-alerts
ALERTMANAGER_PAGERDUTY_ROUTING_KEY=
ALERTMANAGER_SMTP_SMARTHOST=smtp.example.com:587
ALERTMANAGER_SMTP_FROM=alerts@example.com
ALERTMANAGER_SMTP_TO=ops@example.com
ALERTMANAGER_SMTP_AUTH_USERNAME=
ALERTMANAGER_SMTP_AUTH_PASSWORD=
ALERTMANAGER_SMTP_REQUIRE_TLS=true

# Isolated test stack (docker-compose.test.yml)
TEST_APP_ENV=test
TEST_DEBUG=true
TEST_SECRET_KEY=test-stack-secret-key
TEST_POSTGRES_USER=postgres
TEST_POSTGRES_PASSWORD=postgres
TEST_POSTGRES_DB=guitaronline_test
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/guitaronline_test
TEST_REDIS_URL=redis://redis:6379/0
TEST_AUTH_RATE_LIMIT_BACKEND=redis
TEST_AUTH_RATE_LIMIT_REDIS_NAMESPACE=auth_rate_limit_test
TEST_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
TEST_AUTH_RATE_LIMIT_REGISTER_REQUESTS=200
TEST_AUTH_RATE_LIMIT_LOGIN_REQUESTS=200
TEST_AUTH_RATE_LIMIT_REFRESH_REQUESTS=400
TEST_AUTH_SELF_REGISTRATION_ENABLED=true
TEST_AUTH_REFRESH_COOKIE_SECURE=false
TEST_FRONTEND_ADMIN_ORIGIN=http://localhost:5174
TEST_APP_HOST_PORT=18000
TEST_POSTGRES_HOST_PORT=15432
TEST_REDIS_HOST_PORT=16379
TEST_ADMIN_UI_API_BASE_URL=/api/v1
TEST_ADMIN_UI_BASE_PATH=/admin/
TEST_BOOTSTRAP_ADMIN_EMAIL=bootstrap-admin@guitaronline.dev
TEST_BOOTSTRAP_ADMIN_PASSWORD=
INTEGRATION_BASE_URL=http://localhost:18000/api/v1
INTEGRATION_HEALTH_URL=http://localhost:18000/health
INTEGRATION_DB_DSN=postgresql://postgres:postgres@localhost:15432/guitaronline_test
